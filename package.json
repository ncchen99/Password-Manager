{
  "name": "password-manager",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "firebase emulators:exec --config firebase/firebase.json --only firestore \"RUN_RULES_TESTS=true vitest run src/sync/rules.test.ts\"",
    "gen:brands": "node scripts/gen-brands.mjs",
    "emulators": "firebase emulators:start --config firebase/firebase.json"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "firebase": "^11.1.0",
    "hash-wasm": "^4.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "daisyui": "^4.12.23",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "simple-icons": "^16.23.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "vite": "^6.0.5"
  }
}
